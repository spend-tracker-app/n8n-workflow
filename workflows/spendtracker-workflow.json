    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\n// const crypto = require('crypto');\nfor (const item of $('CreateTransactionEntry').all()) {\n  if (item.json.currency == \"SGD\") {\n    item.json.amount_base_currency = item.json.amount\n  } else {\n    item.json.amount_base_currency = item.json.amount / $(\"GetConversionRates\").first().json.sgd[item.json.currency.toLowerCase()]\n    item.json.amount_base_currency = Math.round(item.json.amount_base_currency * 100) / 100\n  }\n  \n  \n  const raw = [\n    item.json.bank,\n    item.json.identifier,\n    item.json.merchant,\n    item.json.amount,\n    item.json.time\n  ].join(\"|\");\n\n\n  item.json.transaction_hash = raw;\n}\n\nreturn $('CreateTransactionEntry').all();"
      },
