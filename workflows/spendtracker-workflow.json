      "id": "7bc4c607-3c12-4c6e-8fac-eb18fd785043",
      "name": "GetConversionRates",
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const entries = $('CreateTransactionEntry').all();\n\nlet rates = null;\ntry {\n  const ratePayload = $('GetConversionRates').first()?.json;\n  rates = ratePayload?.sgd ?? null;\n} catch (e) {\n  rates = null;\n}\n\nfor (const item of entries) {\n  const currency = String(item.json.currency || '').toUpperCase();\n  const amount = Number(item.json.amount);\n\n  // Safe fallback: if FX rate is unavailable/invalid, keep original amount\n  item.json.amount_base_currency = amount;\n\n  if (currency !== 'SGD' && Number.isFinite(amount)) {\n    const rate = Number(rates?.[currency.toLowerCase()]);\n    if (Number.isFinite(rate) && rate > 0) {\n      item.json.amount_base_currency = Math.round((amount / rate) * 100) / 100;\n      item.json.fx_fallback_used = false;\n    } else {\n      item.json.fx_fallback_used = true;\n    }\n  } else {\n    item.json.fx_fallback_used = false;\n  }\n\n  const raw = [\n    item.json.bank,\n    item.json.identifier,\n    item.json.merchant,\n    item.json.amount,\n    item.json.time\n  ].join('|');\n\n  item.json.transaction_hash = raw;\n}\n\nreturn entries;"
      },
      "type": "n8n-nodes-base.code",
