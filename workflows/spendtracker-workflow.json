    {
      "parameters": {
        "jsCode": "// Loop over input items\nlet result = []\nfor (const item of $input.all()) {\n  const plainText = item.json.textPlain;\n\n  if (plainText && plainText.includes(\"UOB\")) {\n    extractUOB(plainText);\n  }\n}\n\nfunction extractUOB(text) {\n  const amountMatch = text.match(/([A-Z]{3})\\s([\\d,]+\\.\\d{2})/);\n  const currency = amountMatch ? amountMatch[1] : null;\n  const amount = amountMatch ? parseFloat(amountMatch[2].replace(/,/g, \"\")) : null;\n\n  const cardMatch = text.match(/Card ending\\s(\\d{4})/i);\n  const cardEnding = cardMatch ? cardMatch[1] : null;\n\n  const merchantMatch = text.match(/at\\s(.+?)\\./i);\n  const merchant = merchantMatch ? merchantMatch[1].trim() : null;\n\n  const dateMatch = text.match(/on\\s(\\d{2}\\/\\d{2}\\/\\d{2})/i);\n  let transactionISO = null;\n\n  if (dateMatch) {\n    const parts = dateMatch[1].split('/');\n    const year = \"20\" + parts[2];\n    const month = parts[1];\n    const day = parts[0];\n    transactionISO = new Date(`${year}-${month}-${day}T12:00:00+08:00`).toISOString();\n  }\n\n  result.push({\n    bank: \"UOB\",\n    merchant,\n    currency,\n    amount,\n    time: transactionISO,\n    identifier: cardEnding,\n    normalize_merchant: normalizeMerchant(merchant || \"\")\n  });\n}\n\nfunction normalizeMerchant(name) {\n  return name.toUpperCase().replace(/[^A-Z0-9]/g, \"\").trim();\n}\n\nreturn result;"
      },
